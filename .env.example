# Copy this file to .env.local and fill in the values.
# .env.local is gitignored and will never be committed.
#
# When adding new environment variables, update the schema in src/env/schema.mjs.

# GitHub personal access token used to authenticate GitHub API requests.
# Without it, the app will hit GitHub's unauthenticated rate limit (60 req/hour).
# Generate one at https://github.com/settings/tokens — no scopes needed for public repo search.
NEXT_PUBLIC_GITHUB_TOKEN="your_github_token_here"